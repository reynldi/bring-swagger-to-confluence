# Application Configuration
VITE_APP_NAME=Swagger Documentation for Confluence
VITE_APP_VERSION=1.0.0

# Deployment Configuration
VITE_BASE_URL=https://your-app-domain.netlify.app

# App Descriptor Configuration (update public/atlassian-connect.json)
# These are not used directly by Vite but are reference values
APP_KEY=swagger-confluence-docs
VENDOR_NAME=Your Organization Name
VENDOR_URL=https://your-website.com

# Security Configuration
# Set to 'production' to disable debug features
NODE_ENV=production

# Optional: Custom branding
VITE_BRAND_COLOR=#1976d2
VITE_BRAND_NAME=Your Company Name

# Netlify Functions Configuration (for health checks)
NETLIFY_FUNCTIONS_URL=/.netlify/functions 